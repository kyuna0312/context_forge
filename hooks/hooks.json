{
  "description": "Warn when CLAUDE.md exceeds token budget thresholds on session start, and record file changes to the forge changelog after Write/Edit.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/session-start.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/record-change.mjs\""
          }
        ]
      }
    ]
  }
}
