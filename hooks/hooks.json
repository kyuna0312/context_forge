{
  "description": "Warn when CLAUDE.md exceeds token budget thresholds on session start.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/session-start.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
